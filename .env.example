# NVIDIA AI provider
AI_API_KEY=
NVIDIA_API_KEY=
AI_ENDPOINT=https://integrate.api.nvidia.com/v1/chat/completions
AI_MODEL=meta/llama-3.1-70b-instruct
AI_REQUEST_TIMEOUT_MS=30000

# Optional structured UI schema providers
UI_SCHEMA_PROVIDER=
UI_SCHEMA_TIMEOUT_MS=30000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_ENDPOINT=https://api.openai.com/v1/chat/completions
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_API_ENDPOINT=

# Optional APIs for advanced skills
NEWS_API_KEY=
IPSTACK_API_KEY=

# Optional: direct browser-to-phone model mode
# Example: http://192.168.1.50:11434 or https://your-tunnel.example
VITE_PHONE_API_BASE=
VITE_PHONE_MODEL=tinyllama
ENABLE_PHONE_PROXY=
PHONE_PROXY_TIMEOUT_MS=120000

# Supabase
SUPABASE_PROJECT_ID=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: custom path for dynamic skills directory
# NABD_SKILLS_DIR=skills
